+/wR');\n    setSpritePosition(Chintu, getHandKeypoint(8));\n    highlightBlock('BHav~t}s/Jh6@=q5*K!n');\n    moveSpriteToPosition(Meteorite, getSpriteAttribute(Chintu, 'p'), 0.1);\n    highlightBlock('IU:4@d^9mscU^nZv)8m9');\n    if (isSpriteTouchingSpriteOrMarker(Meteorite, Chintu)) {\n      highlightBlock('^j[dJe!moX[!vvZqV+E*');\n      playTone('{\"src\":\"https://assets.avishkaar.cc/ams_play/7/Lose\",\"id\":\"Lose\"}', 50);\n    }\n    highlightBlock('xn3sW9kXbdE%G$CMmmBC');\n    if (isSpriteTouchingSpriteOrMarker(Meteorite, Chintu)) {\n      highlightBlock('+jHT+l8mIV@8(EIh+7vX');\n      stopGameLoop()\n      highlightBlock(':Ej#3[u-XMX^WRj3q9O|');\n      showText('Game Over', 50, '#cc0000', (createPosition(getWorldAttribute('hw'), getWorldAttribute('hh'))));\n    }\n  }\n  highlightBlock('%s?L0GNI*Sc`w0UqK(2(');\n  Score = p5Ref.getGameTimerValue('sec');\n  highlightBlock(')?1=pJW=}yKX3e:rr6S*');\n  setScore(Score)\n  }\n  } catch (err) {\n  console.error(err);\n  p5Ref.printToConsole(err.toString());\n  p5Ref.setReactState('gameError', true)\n  }\n}\nhighlightBlock('q-Q|g?~2VRp-v`KVAJ-2');\nconst setup = function () {\n  try {\n  createCanvas();\n  enableCamera();\n  highlightBlock('eS3Gd-=k!8Y!U{5z4Pte');\n  playBackgroundMusic('{\"src\":\"https://assets.avishkaar.cc/ams_play/25/Space%20Adventures\",\"id\":\"Space Adventures\"}', 40);\n  highlightBlock('$w16:RHS,u_bhLn)]TNm');\n  Score = 0;\n  highlightBlock('m#M8LWc%JU/W/)HKM3a-');\n  setScore(Score)\n  highlightBlock('X|4$MRQG8p[ETB.yrvC+');\n  setBackgroundImage('Space 1', 78);\n  highlightBlock('@=_o1OqV[Ui,~GQGhUJ%');\n  Chintu = createSprite('Alien 10', true);\n  highlightBlock('--7y$/]GDu;2)5o,7B$W');\n  setSpriteScale(Chintu, 50);\n  highlightBlock('PSzqjbft~lw/`=k3aHbM');\n  Meteorite = createSprite('Meteor 6', false);\n  highlightBlock('#3z8DF50n7L^s7,?T;$.');\n  setSpriteScale(Meteorite, 70);\n  highlightBlock('mo]SuoxSYefz-Nti){s4');\n  setSpritePosition(Meteorite, (createPosition(getWorldAttribute('w'), 0)));\n  highlightBlock('D}z;E0Z8srI5Nk3+(}:v');\n  Score = p5Ref.getGameTimerValue('sec');\n  p5Ref.setLoader(false);\n  } catch (err) {\n  p5Ref.setLoader(false);\n  console.error(err);\n  p5Ref.printToConsole(err.toString());\n  p5Ref.setReactState('gameError', true)\n  }\n}\n","program_type":"block","diagram":{"parts":[{"type":"wokwi-makerboard","id":"mkb","top":0,"left":0,"attrs":{}}],"connections":[]},"unityContext":null,"aiLabelList":null,"aiCategory":"video","userAssetsList":{"Sprites":[{"src":"https://assets.avishkaar.cc/ams_play/1/alien1.png","id":"Alien 1"},{"id":"Alien 10","src":"https://assets.avishkaar.cc/ams_play/1/Alien%2010"},{"id":"Meteor 6","src":"https://assets.avishkaar.cc/ams_play/21/Meteor%206"}],"Bg Images":[{"src":"https://assets.avishkaar.cc/ams_play/3/space1.png","id":"Space 1"}],"Bg Music":[{"src":"https://assets.avishkaar.cc/ams_play/4/upbeat1.mp3","id":"Upbeat 1"},{"id":"Space Adventures","src":"https://assets.avishkaar.cc/ams_play/25/Space%20Adventures"}],"Tones":[{"src":"https://assets.avishkaar.cc/ams_play/5/Destroy","id":"Destroy"},{"id":"Lose","src":"https://assets.avishkaar.cc/ams_play/7/Lose"}]},"plugin":null}